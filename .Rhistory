ToRho <- function(x, lambda) {
x <- as.vector(x)
lambda <- as.matrix(lambda)
x.norm <- lambda %*% x
x.norm.contrib <- lambda %*% diag(x)
colnames(x.norm.contrib) <- colnames(lambda)
x.norm.contrib1 <- x.norm.contrib[, colSums(x.norm.contrib) > 0, drop = FALSE]
norm.pr.peer <- colSums(x.norm.contrib1)
total.norm <- sum(norm.pr.peer)
Torg.Rho <- as.matrix(norm.pr.peer / total.norm)
colnames(Torg.Rho) <- "Torg.Rho"
return(Torg.Rho)
}
# Eksempeldata
df <- read.csv("rd_frisch_fha.csv")  # eller bruk data.frame direkte
# Resultatliste
rho_resultater <- list()
# Anta at du har en lambda-matrise per DMU i en liste kalt lambda_list
for (i in 1:nrow(df)) {
dmu_id <- df$id[i]
x <- as.numeric(df[i, c("fha_rd_wv.ol", "fha_rd_wv.uc", "fha_rd_wv.sc", "fha_rd_wv.ss")])
lambda <- lambda_list[[i]]  # må være definert på forhånd
rho <- ToRho(x, lambda)
rho_resultater[[as.character(dmu_id)]] <- rho
}
